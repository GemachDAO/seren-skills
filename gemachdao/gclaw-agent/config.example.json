{
  "version": "1",
  "agents": [
    {
      "name": "gclaw-agent",
      "provider": "openai",
      "model": "gpt-4o",
      "system_prompt": "You are an autonomous DeFi trading agent powered by GMAC metabolism. Your goal is to grow your GMAC balance through profitable trades. Analyze market conditions, execute trades via GDEX SDK, and report outcomes. When in survival mode, prioritize high-probability trades.",
      "tools": ["gdex_trade", "gdex_portfolio", "gdex_trending", "web_search", "shell"],
      "cron": [
        {
          "schedule": "*/15 * * * *",
          "task": "Check portfolio drift. If any position is more than 5% off target allocation, rebalance."
        },
        {
          "schedule": "0 * * * *",
          "task": "Scan top trending tokens on Solana. Report any with volume > $500k and price momentum > 3% in last hour."
        }
      ],
      "channels": [],
      "metabolism": {
        "enabled": true,
        "gmac_per_inference": 1,
        "survival_threshold": 100
      }
    }
  ],
  "providers": {
    "openai": {
      "api_key": "${OPENAI_API_KEY}",
      "base_url": "https://api.openai.com/v1"
    },
    "anthropic": {
      "api_key": "${ANTHROPIC_API_KEY}"
    },
    "google": {
      "api_key": "${GOOGLE_AI_API_KEY}"
    },
    "zhipu": {
      "api_key": "${ZHIPU_API_KEY}"
    },
    "openrouter": {
      "api_key": "${OPENROUTER_API_KEY}"
    },
    "ollama": {
      "base_url": "http://localhost:11434"
    }
  },
  "metabolism": {
    "enabled": true,
    "wallet_private_key": "${CONTROL_WALLET_PRIVATE_KEY}",
    "initial_gmac": 1000,
    "replenish_on_profit": true
  },
  "replication": {
    "enabled": false,
    "max_children": 3,
    "min_gmac_to_replicate": 5000,
    "mutation_rate": 0.1
  },
  "swarm": {
    "enabled": false,
    "role": "worker",
    "coordinator_url": "http://localhost:18791",
    "consensus_threshold": 0.66
  },
  "channels": {
    "telegram": {
      "token": "${TELEGRAM_BOT_TOKEN}",
      "allowed_users": []
    },
    "discord": {
      "token": "${DISCORD_BOT_TOKEN}",
      "guild_id": "",
      "channel_id": ""
    }
  },
  "tools": {
    "gdex": {
      "api_key": "${GDEX_API_KEY}",
      "default_chain": "solana"
    },
    "shell": {
      "enabled": true,
      "allowed_commands": ["ls", "cat", "echo", "date", "curl"]
    },
    "web": {
      "enabled": true,
      "max_pages_per_session": 10
    },
    "filesystem": {
      "enabled": true,
      "allowed_paths": ["~/gclaw-workspace"]
    }
  },
  "gateway": {
    "port": 18790,
    "host": "localhost",
    "enable_web_dashboard": true,
    "enable_api": true,
    "cors_origins": ["http://localhost:3000"]
  },
  "recode": {
    "enabled": false,
    "require_approval": true,
    "max_prompt_length": 4096
  }
}
